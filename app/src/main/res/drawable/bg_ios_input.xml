<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background color -->
    <solid android:color="@color/ios_bg" />

    <!-- Border / stroke -->
    <stroke
        android:width="1dp"
        android:color="@color/bottom_nav_active" />

    <!-- Rounded corners -->
    <corners android:radius="12dp" />

    <!-- Optional padding -->
    <padding
        android:left="12dp"
        android:top="8dp"
        android:right="12dp"
        android:bottom="8dp" />

</shape>
