<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_ios_dialog">

     <TextView
        android:fontFamily="@font/p"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Custom Dialog"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="@color/ios_text_primary"
        android:paddingBottom="12dp"/>

     <EditText
        android:fontFamily="@font/y"
        android:id="@+id/etName"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:hint="Ismingizni kiriting"
        android:maxLines="1"
        android:inputType="textPersonName"
        android:paddingHorizontal="14dp"
        android:textSize="15sp"
        android:textColor="@color/ios_text_primary"
        android:textColorHint="@color/ios_text_hint"
        android:background="@drawable/bg_ios_input"/>

     <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:background="@color/ios_divider"/>

     <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal">

        <TextView
            android:fontFamily="@font/r"
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Cancel"
            android:textSize="16sp"
            android:textColor="@color/ios_blue"/>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/ios_divider"/>

        <TextView
            android:fontFamily="@font/r"
            android:id="@+id/btnOk"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="OK"
            android:textSize="16sp"
            android:textColor="@color/ios_blue"/>
    </LinearLayout>

</LinearLayout>
