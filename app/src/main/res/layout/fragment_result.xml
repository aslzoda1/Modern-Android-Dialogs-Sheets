<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="24dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_bg"
    android:fillViewport="true">

    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

         <TextView
            android:fontFamily="@font/p"
            android:text="Your Result"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/ios_text_primary"
            android:paddingBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

         <TextView
            android:id="@+id/tvScore"
            android:fontFamily="@font/s"
            android:text="0 / 10"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="@color/ios_text_primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

         <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressScore"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_marginTop="20dp"
            android:progress="0"
            android:max="10"
            app:indicatorColor="@color/ios_blue"
            app:trackColor="@color/ios_gray"/>

         <TextView
            android:id="@+id/tvMotivation"
            android:fontFamily="@font/y"
            android:text="Motivation"
            android:textSize="18sp"
            android:textColor="@color/ios_text_secondary"
            android:paddingTop="20dp"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

         <TextView
            android:id="@+id/tvDate"
            android:fontFamily="@font/m"
            android:text="Date"
            android:textSize="14sp"
            android:textColor="@color/ios_text_secondary"
            android:paddingTop="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

         <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetry"
            android:fontFamily="@font/p"
            android:text="Quizni qayta ishlash"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:layout_marginTop="30dp"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:backgroundTint="@color/ios_blue"
            app:cornerRadius="16dp"
            android:elevation="0dp"
            android:stateListAnimator="@null"/>

    </LinearLayout>

</ScrollView>
