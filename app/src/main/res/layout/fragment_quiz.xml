<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_bg">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mainCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/ios_blue_light">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@color/ios_card_bg">

                 <TextView
                    android:id="@+id/txtTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Quiz Time"
                    android:textColor="@color/ios_text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:fontFamily="@font/p"
                    android:paddingBottom="16dp"/>

                 <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressBar"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:progress="0"
                    app:indicatorColor="@color/ios_blue"
                    app:trackColor="@color/ios_gray_light"/>

                 <TextView
                    android:id="@+id/txtQuestion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Savol"
                    android:textSize="18sp"
                    android:textColor="@color/ios_text_primary"
                    android:gravity="center"
                    android:fontFamily="@font/y"
                    android:layout_marginTop="24dp"/>

                 <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOption1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Option 1"
                    android:textStyle="bold"
                    android:textColor="@color/ios_text_primary"
                    android:backgroundTint="@color/ios_card_option_bg"
                    android:fontFamily="@font/m"
                    app:cornerRadius="14dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="@color/ios_gray"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOption2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"
                    android:text="Option 2"
                    android:textColor="@color/ios_text_primary"
                    android:backgroundTint="@color/ios_card_option_bg"
                    android:fontFamily="@font/m"
                    app:cornerRadius="14dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="@color/ios_gray"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOption3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Option 3"
                    android:textColor="@color/ios_text_primary"
                    android:backgroundTint="@color/ios_card_option_bg"
                    android:fontFamily="@font/m"
                    android:textStyle="bold"
                    app:cornerRadius="14dp"
                    app:strokeWidth="1.5dp"
                    app:strokeColor="@color/ios_gray"/>

                 <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNext"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="20dp"
                    android:text="NEXT"
                    android:textColor="@color/ios_text_primary_contrast"
                    android:backgroundTint="@color/ios_blue"
                    android:textStyle="bold"
                    android:fontFamily="@font/d"
                    app:cornerRadius="18dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
